{
  "name": "antigravity-zh-cn-pack",
  "displayName": "Antigravity 智能体模式简中包",
  "version": "0.3.0",
  "description": "为 Antigravity 智能体模式提供简体中文规则、技能、钩子与可回滚 UI 注入。",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "antigravity": "2.0.11 || 2.1.4",
    "platform": "darwin-arm64"
  },
  "categories": [
    "Localization",
    "Agent"
  ],
  "activationEvents": [
    "onStartup",
    "onAgentMode"
  ],
  "contributes": {
    "skills": [
      {
        "id": "antigravity-zh-cn",
        "path": "skills/antigravity-zh-cn/SKILL.md"
      }
    ],
    "rules": [
      {
        "id": "zh-cn-agent",
        "path": "rules/zh-cn-agent.md"
      }
    ],
    "hooks": [
      {
        "id": "zh-cn-agent-policy",
        "command": "node",
        "args": [
          "hooks/zh-cn-agent-policy.mjs"
        ]
      }
    ],
    "sidecars": [
      {
        "id": "ui-localizer",
        "path": "sidecars/ui-localizer/sidecar.json"
      }
    ]
  }
}
