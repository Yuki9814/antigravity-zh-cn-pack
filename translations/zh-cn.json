  "selectors": {
    "skip": [
      "pre",
      "code",
      "kbd",
      "samp",
      "textarea",
      "input[type=\"text\"]",
      "input[type=\"search\"]",
      ".monaco-editor",
      ".cm-editor",
      ".xterm",
      ".terminal",
      "[contenteditable=\"true\"]",
      "[data-language]",
      "[data-ag-zh-skip]"
    ],
    "force": [
      "button",
      "[role=\"button\"]",
      "[role=\"menu\"]",
      "[role=\"menuitem\"]",
      "[data-headlessui-state]",
      "[aria-label]",
      "[title]",
      "[placeholder]"
    ]
  },
  "protected": {
    "brands": [
      "\\b(?:Antigravity|Gemini|OpenAI|Claude|GPT|Google Drive|Google Workspace|Google Cloud|Chrome|Chromium|Node\\.js|macOS|MCP|CDP|Jetski|Best of N)\\b"
    ],
    "models": [
      "\\b(?:gemini|claude|gpt|o[0-9]|deepseek|llama|qwen)[A-Za-z0-9_.:/-]*\\b"
    ],
    "commands": [
      "\\b(?:npm|pnpm|yarn|node|git|curl|open|lsof|plutil|rg|osascript|launchctl|blaze)(?:\\s+[A-Za-z0-9_./:@=,%+\\-]+){0,16}"
    ],
    "paths": [
      "(?:^|\\s)(?:/|~/|\\./|\\.\\./)[^\\s]+",
      "\\b[A-Za-z0-9_.-]+\\.(?:mjs|cjs|js|json|md|ts|tsx|jsx|css|html|asar|plist|png|jpg|jpeg|svg|log)\\b"
    ],
    "urls": [
      "\\bhttps?://[^\\s]+",
      "\\b(?:plugin|file|data|app)://[^\\s]+"
    ],
    "shortcuts": [
      "\\b(?:Command|Cmd|Ctrl|Control|Shift|Option|Alt|Enter|Escape)\\s*\\+\\s*[A-Za-z0-9`/\\\\[\\]?,.=-]+\\b",
      "\\bCmdOrCtrl\\+[A-Za-z0-9`/\\\\[\\]?,.=-]+\\b"
    ],
    "code": [
      "```[\\s\\S]*?```",
      "`[^`]*`",
      "\\$\\{[^}]+\\}",
      "\\b[a-zA-Z_$][\\w$]*\\([^)]*\\)"
    ]
  },
  "preservePatterns": [
    "```[\\s\\S]*?```",
    "`[^`]*`"
  ]
}
